generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COUPLE_OWNER
  COUPLE_EDITOR
}

enum RSVPStatus {
  YES
  NO
}

enum OrderStatus {
  PENDING_PAYMENT
  AWAITING_CONFIRMATION
  PAID
  CANCELED
  EXPIRED
}

enum GiftMode {
  UNIQUE
  REPEATABLE
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role           @default(COUPLE_OWNER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  coupleMembers CoupleMember[]
  markedOrders  GiftOrder[]    @relation("MarkedBy")
  logs          AuditLog[]
}

model Couple {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members     CoupleMember[]
  wedding     Wedding?
  pixSetting  PixSetting?
  gifts       WeddingGift[]
  guests      Guest[]
  rsvps       Rsvp[]
  orders      GiftOrder[]
  logs        AuditLog[]
}

model CoupleMember {
  id        String   @id @default(cuid())
  userId    String
  coupleId  String
  role      Role     @default(COUPLE_OWNER)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@unique([userId, coupleId])
}

model Wedding {
  id             String           @id @default(cuid())
  coupleId        String           @unique
  title          String
  subtitle       String?
  story          String?
  eventDate      DateTime?
  location       String?
  published      Boolean          @default(false)
  isRsvpOpen     Boolean          @default(false)
  rsvpRestricted Boolean          @default(true)
  rsvpPasscode   String?
  templateId     String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  couple         Couple           @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  template       Template?        @relation(fields: [templateId], references: [id])
  sections       WeddingSection[]
  gallery        GalleryPhoto[]
}

model Template {
  id          String    @id @default(cuid())
  key         String    @unique
  name        String
  description String?
  previewUrl  String?
  tokensJson  Json
  layoutJson  Json
  createdAt   DateTime  @default(now())
  weddings    Wedding[]
}

model WeddingSection {
  id        String   @id @default(cuid())
  weddingId String
  type      String
  title     String?
  content   String?
  order     Int      @default(0)
  enabled   Boolean  @default(true)
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  weddingId String
  imageUrl  String
  caption   String?
  order     Int      @default(0)
  wedding   Wedding  @relation(fields: [weddingId], references: [id], onDelete: Cascade)
}

model Guest {
  id             String   @id @default(cuid())
  coupleId        String
  fullName       String
  normalizedName String
  maxCompanions  Int      @default(0)
  passcode       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  couple         Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([coupleId, normalizedName])
}

model Rsvp {
  id            String     @id @default(cuid())
  coupleId      String
  guestName     String
  normalizedName String
  status        RSVPStatus
  companions    Int        @default(0)
  message       String?
  source        String?
  meta          Json?
  createdAt     DateTime   @default(now())
  couple        Couple     @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model PixSetting {
  id          String   @id @default(cuid())
  coupleId     String   @unique
  pixKey      String
  receiverName String
  city        String
  txidPrefix  String    @default("WED")
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model GiftCatalogItem {
  id          String        @id @default(cuid())
  title       String
  category    String
  description String
  imageStyle  String
  imagePrompt String
  imageUrl    String?
  tags        String[]
  createdAt   DateTime      @default(now())
  weddingGifts WeddingGift[]
}

model WeddingGift {
  id            String      @id @default(cuid())
  coupleId      String
  catalogItemId String
  active        Boolean     @default(false)
  priceCents    Int         @default(0)
  giftMode      GiftMode    @default(UNIQUE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  couple        Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  catalogItem   GiftCatalogItem @relation(fields: [catalogItemId], references: [id], onDelete: Cascade)
  orders        GiftOrder[]

  @@unique([coupleId, catalogItemId])
}

model GiftOrder {
  id                String      @id @default(cuid())
  coupleId          String
  weddingGiftId     String
  giverName         String
  message           String?
  status            OrderStatus @default(PENDING_PAYMENT)
  amountCents       Int
  pixTxid           String      @unique
  reservedUntil     DateTime?
  markedPaidAt      DateTime?
  markedPaidByUserId String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  couple            Couple      @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  weddingGift       WeddingGift @relation(fields: [weddingGiftId], references: [id], onDelete: Cascade)
  markedPaidBy      User?       @relation("MarkedBy", fields: [markedPaidByUserId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String?
  userId      String?
  coupleId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  couple      Couple?  @relation(fields: [coupleId], references: [id], onDelete: SetNull)
}
